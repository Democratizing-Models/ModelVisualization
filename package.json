    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  }
}
