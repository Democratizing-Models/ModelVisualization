- metadata
    XS3-version: 0.0.1-pre
    author: DEMOS-laser + Hans Peter
    date: 23 April 2026
    description: A simple Gaussian fitting example.

- data_x:
    id: x
    type: data
    values: [-4.  , -3.  , -2.5 , -2.  , -1.5 ,
             -1.  , -0.5 , -0.25,  0.  ,  0.25,
              0.5 ,  1.  ,  1.5 ,  2.  ,  2.5 ,
              3.  ,  4.  ]
    description: x data.

- data_y:
    id: y
    type: data
    values: [ 0.02634095, -0.01312172,  0.21335725,  0.34005899,  0.69794537,
              1.28961702,  1.7800164 ,  1.87450291,  1.99296866,  1.87032235,
              1.93604285,  1.50600478,  0.97602539,  0.385479  ,  0.19294624,
              0.07438064,  0.02545405]
    description: y data.

- parameters_fit:
    id: p
    type: array(real)
    description: Fit parameters.

- init_parameters_fit:
    id: p0
    type: array(real)
    values: [1.0,1.0,1.0]
    description: Initial fit parameters.

- covariance:
    id: pcov
    type: array(real)
    description: Covariance array. Size (2,2).

- y_fit:
    id: y_fit
    type: data
    description: y data produced by a fitting function. Size like data_y.

- curve_fit:
    type: function
    inputs: {"x": x,
             "y": y,
             "function": gaussian_func,
             "parameter": p0,
             "maxiter": 1000}
    outputs: {"y_fit": y_fit,
              "popt": p,
              "pcov": pcov}
    description: Fitting data (x,y) using an gaussian_func and initial parameters p0.

- chisquare_func
    id: chisquare
    type: function
    inputs: {"f_obs: y_fit,
             "f_ref": y}
    outputs: {"chisquare": out_chisquare}
    description: Returns $\chi^2$ error.

- fit_ws:
    id: fit
    type: workspace
    outputs: {"goodness_of_fit": out_chisquare}
    description: Performs a fit using an gaussian_func and returns the respective $\chi^2$ error.
