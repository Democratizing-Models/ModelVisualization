{
    "metadata": {
        "XS3-version": " 0.0.1-pre",
        "author": " DEMOS-laser + Hans Peter",
        "date": " 23 April 2026",
        "description": " A simple Gaussian fitting example."
    },
    "data_x": {
        "id": "x",
        "type": "data",
        "values": [
            -4.0,
            -3.0,
            -2.5,
            -2.0,
            -1.5,
            -1.0,
            -0.5,
            -0.25,
            0.0,
            0.25,
            0.5,
            1.0,
            1.5,
            2.0,
            2.5,
            3.0,
            4.0
        ],
        "description": " x data."
    },
    "data_y": {
        "id": "y",
        "type": "data",
        "values": [
            0.02634095,
            -0.01312172,
            0.21335725,
            0.34005899,
            0.69794537,
            1.28961702,
            1.7800164,
            1.87450291,
            1.99296866,
            1.87032235,
            1.93604285,
            1.50600478,
            0.97602539,
            0.385479,
            0.19294624,
            0.07438064,
            0.02545405
        ],
        "description": " y data."
    },
    "parameters_fit": {
        "id": "p",
        "type": "array(real)",
        "description": " Fit parameters."
    },
    "init_parameters_fit": {
        "id": "p0",
        "type": "array(real)",
        "values": [
            1.0,
            1.0,
            1.0
        ]
    },
    "covariance": {
        "id": "pcov",
        "type": "array(real)",
        "description": " Covariance array. Size (2,2)."
    },
    "y_fit": {
        "id": "y_fit",
        "type": "data",
        "description": " y data produced by a fitting function. Size like data_y."
    },
    "curve_fit": {
        "id": "curve_fit",
        "type": "function",
        "call_type": "curve_fit_call",
        "description": " Represents a costum curve_fit function."
    },
    "curve_fit_call": {
        "id": "curve_fit_call",
        "type": "function_call",
        "description": " Fitting data (x,y) using an gaussian_func and initial parameters p0.",
        "inputs": {
            "x": "x",
            "y": "y",
            "function": "gaussian",
            "parameter": "p0",
            "maxiter": "1000"
        },
        "outputs": {
            "popt": "p",
            "pcov": "pcov"
        }
    },
    "gaussian": {
        "id": "gaussian",
        "type": "function",
        "call_type": "gaussian_call",
        "description": " Represents a Gaussian function $Gaussian(x,p) = a*exp(-(x-mu)^2/(2*sigma^2))$, where p = [a,mu,sigma] is are parameters."
    },
    "gaussian_call": {
        "id": "gaussian_call",
        "type": "function_call",
        "description": " Evaluation of a Gaussian(x,p).",
        "inputs": {
            "x": "x",
            "parameter": "p"
        },
        "outputs": {
            "y_fit": "y_fit"
        }
    },
    "chisquare_func": {
        "id": "chisquare",
        "type": "function",
        "call_type": "chisquare_call",
        "description": " Represents a chisquare function."
    },
    "chisquare_func_call": {
        "id": "chisquare_call",
        "type": "function_call",
        "description": " Returns $\\chi^2$ error.",
        "inputs": {
            "f_obs": "y_fit",
            "f_ref": "y"
        },
        "outputs": {
            "chisquare": "out_chisquare"
        }
    },
    "fit_ws": {
        "id": "fit_ws",
        "type": "workspace",
        "description": " Performs a fit using an gaussian_func and returns the respective $\\chi^2$ error.",
        "outputs": {
            "goodness_of_fit": "out_chisquare"
        }
    }
}
