- preamble:
    type: NampedTuple
    values: {"identifier": preamble,
             "XS3_version": 0.0.1-dev.1,
   	     "author": "DEMOS-laser + Hans Peter",
             "date": 2026-06-11,
             "description": Example-04 stocastic transport model.}

- data:
    identifier: data
    type: data
    values: [3.81359, 2.91195, 3.20085 , 3.09185 ,
             3.34005, 4.96067, 0.842412, 2.34128 ,
             3.06224, 2.59162, 2.5017  , 5.39892 ,
             1.19806, 1.60855, 1.44647 , 0.771489,
             0.26153, 1.56184, 0.561171, 4.4823]
    description: data.

- parameters:
    identifier: parameters
    type: array(real)
    values: [0.1,0.3,1.1,0.2]
    description: Transport parameters: a=0.1,b=0.3,mu=1.1,sigma=0.2.

- gun
    type: samplable
    identifier: gun_dist
    weighting_type: gun_dist_weighting_call
    sampling_type: gun_dist_sampling_call
    description: Represents a Gun/Normal(mu,sigma) = $1./\sqrt(2.*\pi*sigma^2.)\exp((x-mu)^2/(2*\sigma)$ distribution.

- gun_dist_weighting_call
    type: weighting_call
    identifier: gun_dist_weighting_call
    inputs: {"x":(real), "mu":(real), "sigma":(real)}
    outputs: {"weight": (real)}
    description: Weighting call for a Gun distribution. Evaluating $1./\sqrt(2.*\pi*sigma^2.)\exp((x-mu)^2/(2*\sigma)$ for samples x.

- gun_dist_sampling_call
    type: sampling_call
    identifier: gun_dist_sampling_call
    inputs: {"rng": (random_state), "mu":(real), "sigma":(real)}
    outputs: {"sample": (real)}
    description: Sampling call for a Gun distribution.

- transport:
    identifier: transport
    type: function
    call_type: transport_call
    description: Mimics heavy transport function (container/engine).

- transport_call:
    identifier: transport_call
    type: function_call
    inputs: {"x": x,
             "parameter": p}
    outputs: {"y": y}
    description: Calling transport function.

- post:
    identifier: post
    type: function
    call_type: post_call
    description: Mimics post-processing function.

- post_call:
    identifier: post_call
    type: function_call
    inputs: {"y": y}
    outputs: {"z": z}
    description: Calling post function.

